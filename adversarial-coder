#!/usr/bin/env bash
# Adversarial Coder - GAN-inspired three-agent harness
# Uses Codex (Generator) + Planner/Evaluator (Gemini or Kimi)

# Don't exit on error - we handle errors explicitly
# set -e  # Commented out to allow graceful error handling

# Colors (only for terminal output, not return values)
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
DIM='\033[2m'
RESET='\033[0m'

# Defaults
MAX_SPRINTS=${MAX_SPRINTS:-10}
MAX_RETRIES=${MAX_RETRIES:-3}
PASS_THRESHOLD=${PASS_THRESHOLD:-7}
CODEX_MODEL=${CODEX_MODEL:-gpt-5.4}
PLANNER_MODEL=${PLANNER_MODEL:-}  # Auto-detect: gemini or kimi
EVALUATOR_MODEL=${EVALUATOR_MODEL:-}  # Auto-detect: gemini or kimi
WORKDIR="${WORKDIR:-$(pwd)/adversarial-workspace}"
TIMEOUT=${TIMEOUT:-120}  # 2 minute default per agent call

# Detect available planner/evaluator
PLANNER_CMD=""
EVALUATOR_CMD=""

detect_planner() {
    if [[ -n "$PLANNER_MODEL" ]]; then
        case "$PLANNER_MODEL" in
            kimi)
                if command -v kimi &>/dev/null; then
                    PLANNER_CMD="kimi --print --yolo -p"
                    return 0
                fi
                ;;
            gemini)
                if command -v gemini &>/dev/null; then
                    PLANNER_CMD="gemini"
                    return 0
                fi
                ;;
        esac
    fi
    
    # Auto-detect: prefer kimi (better for agentic workflows), fallback to gemini
    if command -v kimi &>/dev/null; then
        PLANNER_CMD="kimi --print --yolo -p"
        PLANNER_MODEL="kimi"
    elif command -v gemini &>/dev/null; then
        PLANNER_CMD="gemini"
        PLANNER_MODEL="gemini"
    else
        echo -e "${RED}Error: No planner available. Install kimi or gemini CLI.${RESET}" >&2
        exit 1
    fi
}

detect_evaluator() {
    if [[ -n "$EVALUATOR_MODEL" ]]; then
        case "$EVALUATOR_MODEL" in
            kimi)
                if command -v kimi &>/dev/null; then
                    EVALUATOR_CMD="kimi --print --yolo -p"
                    return 0
                fi
                ;;
            gemini)
                if command -v gemini &>/dev/null; then
                    EVALUATOR_CMD="gemini"
                    return 0
                fi
                ;;
        esac
    fi
    
    # Use same as planner by default
    EVALUATOR_CMD="$PLANNER_CMD"
    EVALUATOR_MODEL="$PLANNER_MODEL"
}

# Parse arguments
PROMPT=""
PROMPT_FILE=""

while [[ $# -gt 0 ]]; do
    case $1 in
        --file|-f)
            PROMPT_FILE="$2"
            shift 2
            ;;
        --max-sprints)
            MAX_SPRINTS="$2"
            shift 2
            ;;
        --max-retries)
            MAX_RETRIES="$2"
            shift 2
            ;;
        --threshold)
            PASS_THRESHOLD="$2"
            shift 2
            ;;
        --workdir)
            WORKDIR="$2"
            shift 2
            ;;
        --timeout)
            TIMEOUT="$2"
            shift 2
            ;;
        --planner)
            PLANNER_MODEL="$2"
            shift 2
            ;;
        --evaluator)
            EVALUATOR_MODEL="$2"
            shift 2
            ;;
        --help|-h)
            echo "Adversarial Coder - GAN-inspired three-agent harness"
            echo ""
            echo "Usage: adversarial-coder [OPTIONS] <PROMPT>"
            echo "       adversarial-coder --file <PROMPT_FILE>"
            echo ""
            echo "Agents:"
            echo "  Planner:    Kimi (preferred) or Gemini (auto-detected)"
            echo "  Generator:  Codex (OpenAI)"
            echo "  Evaluator:  Same as Planner"
            echo ""
            echo "Options:"
            echo "  --file, -f         Read prompt from file"
            echo "  --max-sprints      Maximum sprints (default: 10)"
            echo "  --max-retries      Max retries per sprint (default: 3)"
            echo "  --threshold        Pass threshold 1-10 (default: 7)"
            echo "  --workdir          Working directory (default: ./adversarial-workspace)"
            echo "  --timeout          Timeout per agent call in seconds (default: 120)"
            echo "  --planner           Planner model: kimi or gemini (default: auto-detect)"
            echo "  --evaluator         Evaluator model: kimi or gemini (default: same as planner)"
            echo "  --help, -h         Show this help"
            exit 0
            ;;
        *)
            PROMPT="$1"
            shift
            ;;
    esac
done

# Get prompt from file if specified
if [[ -n "$PROMPT_FILE" ]]; then
    if [[ ! -f "$PROMPT_FILE" ]]; then
        echo -e "${RED}Error: File not found: $PROMPT_FILE${RESET}" >&2
        exit 1
    fi
    PROMPT=$(cat "$PROMPT_FILE")
fi

if [[ -z "$PROMPT" ]]; then
    echo -e "${RED}Error: No prompt provided${RESET}" >&2
    echo "Usage: adversarial-coder <PROMPT>" >&2
    echo "       adversarial-coder --file <PROMPT_FILE>" >&2
    exit 1
fi

# Logging functions
log() { echo -e "${DIM}$(date +%H:%M:%S)${RESET} ${CYAN}[HARNESS]${RESET} $1" >&2; }
log_planner() { echo -e "${DIM}$(date +%H:%M:%S)${RESET} ${MAGENTA}[PLANNER]${RESET} $1" >&2; }
log_generator() { echo -e "${DIM}$(date +%H:%M:%S)${RESET} ${GREEN}[GENERATOR]${RESET} $1" >&2; }
log_evaluator() { echo -e "${DIM}$(date +%H:%M:%S)${RESET} ${YELLOW}[EVALUATOR]${RESET} $1" >&2; }
log_error() { echo -e "${DIM}$(date +%H:%M:%S)${RESET} ${RED}[ERROR]${RESET} $1" >&2; }
log_divider() { echo -e "\n${DIM}────────────────────────────────────────────────────────────${RESET}\n" >&2; }

# Initialize workspace
init_workspace() {
    log "Initializing workspace: $WORKDIR"
    mkdir -p "$WORKDIR"/{contracts,feedback,app}
    
    # Clean stale artifacts
    rm -f "$WORKDIR/spec.md" "$WORKDIR/progress.json" 2>/dev/null || true
    rm -f "$WORKDIR/contracts"/*.json 2>/dev/null || true
    rm -f "$WORKDIR/feedback"/*.json 2>/dev/null || true
    
    # Initialize git repo in app/
    if [[ ! -d "$WORKDIR/app/.git" ]]; then
        cd "$WORKDIR/app"
        git init -q 2>/dev/null || true
        git commit --allow-empty -m "Initial commit" -q 2>/dev/null || true
    fi
}

# Phase 1: Planning - returns number of sprints
run_planner() {
    log_divider
    log "PHASE 1: PLANNING"
    log_divider
    
    log_planner "Starting planning for: \"$PROMPT\""
    
    local planner_prompt="You are a product architect. Your job is to take a brief user description and produce a product specification.

## Your Responsibilities

1. Expand the user's description into a product specification
2. Define a clear feature list organized into sprints (1-3 sprints for simple tasks, 3-6 for complex)
3. Stay REASONABLE - match scope to complexity (a simple script doesn't need enterprise architecture)
4. Stay HIGH-LEVEL - do NOT specify granular implementation details

## Output Format

Write a product specification as markdown. Include:

### Product Overview
- What the product does
- Core value proposition

### Tech Stack
- Appropriate tech stack (keep it simple for simple tasks)

### Feature List
For each feature:
- Feature name
- Brief description
- Which sprint it belongs to

### Sprint Plan
Use 1 sprint for simple tasks, 2-3 for medium tasks, 3-6 for complex projects.
Each sprint should have a clear theme.

## Rules
- BE REASONABLE - a 'Hello World' script doesn't need microservices
- Match complexity to the actual request
- Keep specs CONCISE - aim for 1-2 pages, not 10
- Do NOT write any code
- Output ONLY the markdown specification

---

User Request: $PROMPT"
    
    cd "$WORKDIR"
    local spec_output
    
    # Use planner (auto-detected: kimi preferred, or gemini) with timeout
    log_planner "Running planner with $PLANNER_MODEL (timeout: ${TIMEOUT}s)..."
    spec_output=$(timeout "$TIMEOUT" $PLANNER_CMD "$planner_prompt" 2>/dev/null) || {
        log_error "Planner timed out or failed"
        echo "3"  # Default sprint count
        return
    }
    
    if [[ -z "$spec_output" ]]; then
        log_error "Planner produced no output"
        echo "3"
        return
    fi
    
    # Write spec.md
    echo "$spec_output" > "$WORKDIR/spec.md"
    
    # Count sprints from headers
    local sprint_count
    sprint_count=$(echo "$spec_output" | grep -cE '##+ Sprint [0-9]+' 2>/dev/null || echo "0")
    
    # Default to 3 if none found
    if [[ -z "$sprint_count" || "$sprint_count" -lt 1 ]]; then
        sprint_count=3
    fi
    
    # Cap at MAX_SPRINTS
    if [[ "$sprint_count" -gt "$MAX_SPRINTS" ]]; then
        sprint_count=$MAX_SPRINTS
    fi
    
    log_planner "Product specification generated ($sprint_count sprints)"
    
    # Return value (just the number)
    echo "$sprint_count"
}

# Contract negotiation
negotiate_contract() {
    local sprint_num=$1
    
    log "Negotiating sprint $sprint_num contract..."
    
    local spec
    spec=$(cat "$WORKDIR/spec.md")
    
    # Extract just this sprint's section from spec
    local sprint_section
    sprint_section=$(echo "$spec" | sed -n "/## Sprint $sprint_num/,/## Sprint $((sprint_num+1))/p" | head -50)
    
    # Generator proposes contract
    local proposal_prompt="You are proposing a sprint contract. Based on the product spec, propose what you will build for Sprint $sprint_num and how success should be measured.

Output a JSON object with this EXACT structure:
\`\`\`json
{
  \"sprintNumber\": $sprint_num,
  \"features\": [\"feature1\", \"feature2\", ...],
  \"criteria\": [
    {
      \"name\": \"criterion_name\",
      \"description\": \"Specific, testable description of what must be true\",
      \"threshold\": 7
    }
  ]
}
\`\`\`

Rules:
- Each criterion must be SPECIFIC and TESTABLE (not vague like \"works well\")
- Include 3-5 criteria per sprint (keep it focused)
- Criteria must cover: functionality, error handling, code quality
- Output ONLY the JSON, no other text

---

Sprint $sprint_num Focus:

$sprint_section"
    
    local proposal
    cd "$WORKDIR"
    
    log_generator "Proposing contract (timeout: ${TIMEOUT}s)..."
    proposal=$(timeout "$TIMEOUT" bash -c "source ~/.nvm/nvm.sh && codex exec --dangerously-bypass-approvals-and-sandbox --skip-git-repo-check '$proposal_prompt'" 2>&1) || {
        log_error "Contract proposal timed out, using default"
        create_default_contract "$sprint_num"
        return
    }
    
    # Extract JSON from proposal
    local proposal_json
    proposal_json=$(echo "$proposal" | sed -n '/```json/,/```/p' | sed '1d;$d' | tr '\n' ' ')
    
    if [[ -z "$proposal_json" ]]; then
        proposal_json=$(echo "$proposal" | grep -oE '\{[^}]*"criteria"[^}]*\}' | head -1)
    fi
    
    # Evaluator reviews contract
    local review_prompt="You are reviewing a proposed sprint contract. Evaluate whether the criteria are specific enough, testable, and comprehensive.

If the contract is good, output exactly: APPROVED

If the contract needs changes, output a revised JSON contract with the same structure but improved criteria. Make criteria more specific, add missing edge cases, or adjust thresholds.

Rules:
- Criteria must be testable by reading code and running the app
- Vague criteria like \"works well\" must be made specific
- Ensure coverage of error handling and edge cases
- Keep criteria focused (3-5 max)
- Output either \"APPROVED\" or the revised JSON contract, nothing else

---

Proposed Sprint Contract:

$proposal_json"
    
    local review
    log_evaluator "Reviewing contract with $EVALUATOR_MODEL (timeout: ${TIMEOUT}s)..."
    review=$(timeout "$TIMEOUT" $EVALUATOR_CMD "$review_prompt" 2>/dev/null) || {
        log "Contract review timed out, using proposal"
        final_contract="$proposal_json"
        # Save contract directly
        echo "$final_contract" > "$WORKDIR/contracts/sprint-$sprint_num.json"
        create_default_contract "$sprint_num"
        return
    }
    
    # Use proposal if approved, otherwise use revised version
    local final_contract
    if echo "$review" | grep -q "APPROVED"; then
        final_contract="$proposal_json"
    else
        # Extract JSON from review
        final_contract=$(echo "$review" | sed -n '/```json/,/```/p' | sed '1d;$d' | tr '\n' ' ')
        if [[ -z "$final_contract" ]]; then
            final_contract=$(echo "$review" | grep -oE '\{[^}]*"criteria"[^}]*\}')
        fi
        if [[ -z "$final_contract" ]]; then
            final_contract="$proposal_json"
        fi
    fi
    
    # Save contract
    echo "$final_contract" > "$WORKDIR/contracts/sprint-$sprint_num.json"
    
    # Validate and fix JSON
    python3 -c "
import sys, json
try:
    with open('$WORKDIR/contracts/sprint-$sprint_num.json') as f:
        data = json.load(f)
    data['sprintNumber'] = $sprint_num
    if 'criteria' not in data or not data['criteria']:
        data['criteria'] = [
            {'name': 'basic_functionality', 'description': 'Core features work correctly', 'threshold': $PASS_THRESHOLD},
            {'name': 'code_quality', 'description': 'Code is clean and well-structured', 'threshold': $PASS_THRESHOLD},
            {'name': 'error_handling', 'description': 'Errors handled gracefully', 'threshold': $PASS_THRESHOLD}
        ]
    with open('$WORKDIR/contracts/sprint-$sprint_num.json', 'w') as f:
        json.dump(data, f, indent=2)
except Exception as e:
    # Create default contract
    data = {
        'sprintNumber': $sprint_num,
        'features': ['Sprint $sprint_num implementation'],
        'criteria': [
            {'name': 'basic_functionality', 'description': 'Core features work correctly', 'threshold': $PASS_THRESHOLD},
            {'name': 'code_quality', 'description': 'Code is clean and well-structured', 'threshold': $PASS_THRESHOLD},
            {'name': 'error_handling', 'description': 'Errors handled gracefully', 'threshold': $PASS_THRESHOLD}
        ]
    }
    with open('$WORKDIR/contracts/sprint-$sprint_num.json', 'w') as f:
        json.dump(data, f, indent=2)
" 2>/dev/null
    
    local criteria_count
    criteria_count=$(python3 -c "import json; print(len(json.load(open('$WORKDIR/contracts/sprint-$sprint_num.json')).get('criteria', [])))")
    
    log "Contract agreed: $criteria_count criteria"
}

create_default_contract() {
    local sprint_num=$1
    python3 -c "
import json
data = {
    'sprintNumber': $sprint_num,
    'features': ['Sprint $sprint_num implementation'],
    'criteria': [
        {'name': 'basic_functionality', 'description': 'Core features work correctly', 'threshold': $PASS_THRESHOLD},
        {'name': 'code_quality', 'description': 'Code is clean and well-structured', 'threshold': $PASS_THRESHOLD},
        {'name': 'error_handling', 'description': 'Errors handled gracefully', 'threshold': $PASS_THRESHOLD}
    ]
}
with open('$WORKDIR/contracts/sprint-$sprint_num.json', 'w') as f:
    json.dump(data, f, indent=2)
"
    log "Using default contract for sprint $sprint_num"
}

# Build phase
run_generator() {
    local sprint_num=$1
    local attempt_num=$2
    local feedback_file="$WORKDIR/feedback/sprint-$sprint_num-round-$((attempt_num-1)).json"
    
    log_generator "Sprint $sprint_num (attempt $attempt_num) - Building..."
    
    local contract
    contract=$(cat "$WORKDIR/contracts/sprint-$sprint_num.json" 2>/dev/null || echo "")
    
    local feedback=""
    if [[ -f "$feedback_file" && $attempt_num -gt 1 ]]; then
        feedback=$(cat "$feedback_file")
    fi
    
    # Build prompt file
    local prompt_file="$WORKDIR/.prompt.txt"
    {
        echo "Implement Sprint $sprint_num features. Work in the app/ directory."
        echo ""
        echo "Sprint Contract:"
        cat "$WORKDIR/contracts/sprint-$sprint_num.json"
        if [[ -n "$feedback" ]]; then
            echo ""
            echo "Evaluation Feedback (fix these issues):"
            cat "$feedback_file"
        fi
    } > "$prompt_file"
    
    cd "$WORKDIR"
    
    # Use Codex with prompt from file via stdin
    log_generator "Running generator (timeout: ${TIMEOUT}s)..."
    timeout "$TIMEOUT" bash -c "cd '$WORKDIR' && source ~/.nvm/nvm.sh && cat '$prompt_file' | codex exec --dangerously-bypass-approvals-and-sandbox --skip-git-repo-check" 2>&1 | tail -100 || {
        log_error "Generator timed out"
        rm -f "$prompt_file"
        return 1
    }
    
    rm -f "$prompt_file"
    log_generator "Sprint $sprint_num build complete"
    return 0
}

# Evaluate phase - returns "true" or "false"
run_evaluator() {
    local sprint_num=$1
    local attempt_num=$2
    
    log_evaluator "Evaluating sprint $sprint_num..."
    
    local contract
    contract=$(cat "$WORKDIR/contracts/sprint-$sprint_num.json")
    
    # List what was built
    local built_files
    built_files=$(find "$WORKDIR/app" -type f -name "*.py" -o -name "*.js" -o -name "*.ts" -o -name "*.go" -o -name "*.rs" 2>/dev/null | head -20 || echo "No files found")
    
    local eval_prompt="You are a skeptical QA engineer. Your job is to rigorously test an application against sprint contract criteria and produce honest, detailed scores.

## Sprint Contract to Evaluate Against

$contract

## Pass Threshold

Each criterion must score at least $PASS_THRESHOLD/10 to pass.

## Files in app/

$built_files

## Scoring Guidelines

- **9-10**: Exceptional. Works perfectly, handles edge cases, clean implementation.
- **7-8**: Good. Core functionality works correctly with minor issues.
- **5-6**: Partial. Some functionality works but significant gaps remain.
- **3-4**: Poor. Fundamental issues, barely functional.
- **1-2**: Failed. Not implemented or completely broken.

## Rules

- Do NOT be generous. Resist the urge to praise the work.
- Do NOT approve mediocre work. When in doubt, fail it.
- Test EVERY criterion in the contract.
- When something fails, provide SPECIFIC details: file paths, error messages.
- Check edge cases, not just the happy path.

## Output Format

Output a JSON object with this EXACT structure and nothing else:

\`\`\`json
{
  \"passed\": true,
  \"scores\": {
    \"criterion_name\": 8,
    \"another_criterion\": 7
  },
  \"feedback\": [
    {
      \"criterion\": \"criterion_name\",
      \"score\": 8,
      \"details\": \"What passed/failed and why\"
    }
  ],
  \"overallSummary\": \"Brief summary\"
}
\`\`\`

A sprint PASSES only if ALL criteria score >= $PASS_THRESHOLD.

Read the code in the \`app/\` directory and score each criterion."
    
    cd "$WORKDIR"
    
    # Use evaluator (auto-detected: kimi or gemini) with timeout
    log_evaluator "Running evaluator with $EVALUATOR_MODEL (timeout: ${TIMEOUT}s)..."
    local eval_output
    eval_output=$(timeout "$TIMEOUT" $EVALUATOR_CMD "$eval_prompt" 2>/dev/null) || {
        log_error "Evaluator timed out"
        echo "false"
        return
    }
    
    # Extract JSON from evaluation
    local eval_json
    eval_json=$(echo "$eval_output" | sed -n '/```json/,/```/p' | sed '1d;$d' | tr '\n' ' ')
    
    if [[ -z "$eval_json" ]]; then
        eval_json=$(echo "$eval_output" | grep -oE '\{[^}]*"passed"[^}]*"feedback"[^}]*\}')
    fi
    
    if [[ -z "$eval_json" ]]; then
        eval_json='{"passed":false,"scores":{},"feedback":[{"criterion":"evaluation_failed","score":0,"details":"Evaluator failed to produce parseable output"}],"overallSummary":"Evaluation parsing failed"}'
    fi
    
    # Save feedback
    echo "$eval_json" | python3 -m json.tool > "$WORKDIR/feedback/sprint-$sprint_num-round-$attempt_num.json" 2>/dev/null || echo "$eval_json" > "$WORKDIR/feedback/sprint-$sprint_num-round-$attempt_num.json"
    
    # Parse results
    local passed
    passed=$(python3 -c "
import json
try:
    with open('$WORKDIR/feedback/sprint-$sprint_num-round-$attempt_num.json') as f:
        data = json.load(f)
    print(str(data.get('passed', False)).lower())
except:
    print('false')
")
    
    local score_count total_count
    score_count=$(python3 -c "import json; print(sum(1 for s in json.load(open('$WORKDIR/feedback/sprint-$sprint_num-round-$attempt_num.json')).get('scores', {}).values() if s >= $PASS_THRESHOLD))")
    total_count=$(python3 -c "import json; print(len(json.load(open('$WORKDIR/feedback/sprint-$sprint_num-round-$attempt_num.json')).get('scores', {})))")
    
    if [[ "$passed" == "true" ]]; then
        log_evaluator "Sprint $sprint_num: PASSED ($score_count/$total_count criteria passed)"
    else
        log_evaluator "Sprint $sprint_num: FAILED ($score_count/$total_count criteria passed)"
    fi
    
    # Return value (just "true" or "false")
    echo "$passed"
}

# Main harness
main() {
    # Detect available planner/evaluator
    detect_planner
    detect_evaluator
    
    log_divider
    log "ADVERSARIAL CODER - Three-Agent Harness"
    log "Planner: $PLANNER_MODEL | Generator: Codex | Evaluator: $EVALUATOR_MODEL"
    log "Max sprints: $MAX_SPRINTS | Max retries: $MAX_RETRIES | Threshold: $PASS_THRESHOLD/10"
    log "Timeout per agent: ${TIMEOUT}s"
    log_divider
    
    init_workspace
    
    # Phase 1: Planning
    local total_sprints
    total_sprints=$(run_planner)
    
    # Ensure we have a valid number
    if ! [[ "$total_sprints" =~ ^[0-9]+$ ]]; then
        total_sprints=3
    fi
    if [[ $total_sprints -lt 1 ]]; then
        total_sprints=1
    fi
    
    # Phase 2-4: Sprint Loop
    local sprint_results=()
    local current_sprint=1
    
    while [[ $current_sprint -le $total_sprints && $current_sprint -le $MAX_SPRINTS ]]; do
        log_divider
        log "SPRINT $current_sprint/$total_sprints"
        log_divider
        
        # Contract negotiation
        negotiate_contract "$current_sprint"
        
        # Build-Evaluate loop
        local passed="false"
        local attempt=1
        
        while [[ $attempt -le $MAX_RETRIES ]]; do
            run_generator "$current_sprint" "$attempt"
            passed=$(run_evaluator "$current_sprint" "$attempt")
            
            if [[ "$passed" == "true" ]]; then
                sprint_results+=("Sprint $current_sprint: PASSED (attempt $attempt)")
                break
            fi
            
            if [[ $attempt -lt $MAX_RETRIES ]]; then
                log "Sprint $current_sprint failed attempt $attempt, retrying..."
            else
                log_error "Sprint $current_sprint FAILED after $attempt attempts"
                sprint_results+=("Sprint $current_sprint: FAILED ($attempt attempts)")
            fi
            
            ((attempt++))
        done
        
        if [[ "$passed" != "true" ]]; then
            log_error "Harness stopped: sprint $current_sprint could not pass evaluation"
            break
        fi
        
        ((current_sprint++))
    done
    
    # Summary
    log_divider
    local all_passed=true
    for result in "${sprint_results[@]}"; do
        log "$result"
        if [[ "$result" == *"FAILED"* ]]; then
            all_passed=false
        fi
    done
    
    if $all_passed && [[ ${#sprint_results[@]} -ge 1 ]]; then
        log "All sprints completed successfully!"
        log "Output in: $WORKDIR/app/"
    else
        log_error "Harness completed with failures"
        log "Check feedback files in: $WORKDIR/feedback/"
    fi
    
    log_divider
    log "To resume or continue building:"
    log "  cd $WORKDIR/app && ls -la"
}

main